              "type": "string"
            },
            "title": "Players",
            "type": "array"
          },
          "rotation_degrees": {
            "title": "Rotation Degrees",
            "type": "integer"
          },
          "side": {
            "title": "Side",
            "type": "string"
          },
          "team": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Team"
          },
          "text_count": {
            "title": "Text Count",
            "type": "integer"
          }
        },
        "required": [
          "players",
          "player",
          "team",
          "card_number",
          "side",
          "rotation_degrees",
